/**
 * 全局样式
 */
page {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

/* 通用卡片样式 */
.card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 16rpx 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 通用按钮 */
.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #1a73e8;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin: 20rpx 0;
}

.btn-primary:active {
  background: #1557b0;
}

.btn-primary[disabled] {
  background: #c0c0c0;
  color: #888888;
}

/* 标签 */
.tag-pass {
  display: inline-block;
  background: #e8f5e9;
  color: #2e7d32;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-fail {
  display: inline-block;
  background: #ffebee;
  color: #c62828;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}