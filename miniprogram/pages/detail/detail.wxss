.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 16rpx;
}

.section {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.device-code { font-size: 32rpx; font-weight: bold; color: #c62828; }
.device-name { font-size: 28rpx; color: #555555; display: block; margin-bottom: 8rpx; }
.meta-row { font-size: 24rpx; color: #888888; display: block; margin-top: 4rpx; }

.section-title {
  font-size: 28rpx; font-weight: bold; color: #333333;
  margin-bottom: 12rpx; padding-bottom: 8rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.item-row {
  display: flex; justify-content: space-between;
  align-items: center; padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.item-row:last-child { border-bottom: none; }

.item-name { font-size: 26rpx; color: #555555; }
.item-right { display: flex; align-items: center; gap: 8rpx; }
.item-value { font-size: 26rpx; color: #333333; font-weight: 500; }
.item-value.abnormal { color: #c62828; font-weight: bold; }

.abnormal-tag {
  background: #ffebee; color: #c62828;
  padding: 2rpx 12rpx; border-radius: 16rpx; font-size: 20rpx;
}

.photo-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.detail-photo { width: 200rpx; height: 200rpx; border-radius: 8rpx; }

.remark-text { font-size: 26rpx; color: #555555; line-height: 1.6; display: block; }
.remark-text.engineer { color: #1a73e8; background: #e8f0fe; padding: 12rpx; border-radius: 8rpx; }
.remark-empty { font-size: 24rpx; color: #999999; }

.tag-pass {
  background: #e8f5e9; color: #2e7d32;
  padding: 4rpx 16rpx; border-radius: 20rpx;
  font-size: 24rpx; font-weight: 500;
}

.tag-fail {
  background: #ffebee; color: #c62828;
  padding: 4rpx 16rpx; border-radius: 20rpx;
  font-size: 24rpx; font-weight: 500;
}