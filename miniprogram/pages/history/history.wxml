<view class="page">
  <view class="list">
    <view class="record-card" wx:for="{{records}}" wx:key="id" data-id="{{item.id}}" bindtap="onCardTap">
      <view class="card-row">
        <text class="device-name">{{item.device_name}}</text>
        <view class="status-group">
          <text class="tag-{{item.result_status === 'pass' ? 'pass' : 'fail'}}">{{item.result_status === 'pass' ? '合格' : '异常'}}</text>
          <text class="badge-processed" wx:if="{{item.engineer_remark}}">已处理 ✓</text>
          <text class="badge-pending" wx:elif="{{item.result_status === 'fail'}}">待处理 ⏳</text>
        </view>
      </view>
      <view class="card-row">
        <text class="device-code">{{item.device_code}}</text>
      </view>
      <view class="card-row">
        <text class="check-time">{{item.check_time}}</text>
      </view>
    </view>
    <view class="empty-tip" wx:if="{{records.length === 0}}">
      <text>暂无历史记录</text>
    </view>
  </view>
</view>