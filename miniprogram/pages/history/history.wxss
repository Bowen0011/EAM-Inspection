.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

.list {
  padding: 0 16rpx;
}

.record-card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.record-card:active { background: #f8f9fa; }

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.device-name { font-size: 30rpx; font-weight: 500; color: #333333; }
.device-code { font-size: 24rpx; color: #888888; }
.check-time { font-size: 24rpx; color: #999999; }

.status-group { display: flex; align-items: center; gap: 8rpx; }

.badge-processed {
  background: #e8f5e9; color: #2e7d32;
  padding: 2rpx 12rpx; border-radius: 16rpx;
  font-size: 20rpx; font-weight: 500;
}

.badge-pending {
  background: #fff3e0; color: #e65100;
  padding: 2rpx 12rpx; border-radius: 16rpx;
  font-size: 20rpx; font-weight: 500;
}

.tag-pass {
  background: #e8f5e9; color: #2e7d32;
  padding: 4rpx 16rpx; border-radius: 20rpx;
  font-size: 24rpx; font-weight: 500;
}

.tag-fail {
  background: #ffebee; color: #c62828;
  padding: 4rpx 16rpx; border-radius: 20rpx;
  font-size: 24rpx; font-weight: 500;
}

.empty-tip {
  text-align: center; padding: 80rpx 0;
  color: #999999; font-size: 28rpx;
}