<view class="page">
  <view class="stats-card">
    <text class="stats-label">今日待点检</text>
    <text class="stats-number">{{taskCount}} 台</text>
  </view>

  <scroll-view class="device-list" scroll-y>
    <view class="device-card" wx:for="{{tasks}}" wx:key="device_code"
      data-device="{{item}}" bindtap="onDeviceTap">
      <view class="card-header">
        <text class="device-code">{{item.device_code}}</text>
      </view>
      <text class="device-name">{{item.device_name}}</text>
      <text class="device-location">{{item.location}}</text>
    </view>

    <view class="empty-tip" wx:if="{{tasks.length === 0}}">
      <text>暂无待点检设备</text>
    </view>
  </scroll-view>
</view>