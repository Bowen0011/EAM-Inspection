.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

.stats-card {
  background: linear-gradient(135deg, #1a73e8, #1557b0);
  margin: 20rpx 16rpx;
  padding: 30rpx 24rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-label {
  color: rgba(255,255,255,0.8);
  font-size: 28rpx;
}

.stats-number {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: bold;
  margin-top: 8rpx;
}

.device-card {
  background: #ffffff;
  margin: 12rpx 16rpx;
  padding: 24rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
}

.device-card:active {
  background: #f0f4ff;
}

.card-header {
  margin-bottom: 8rpx;
}

.device-code {
  color: #c62828;
  font-size: 28rpx;
  font-weight: bold;
}

.device-name {
  color: #333333;
  font-size: 30rpx;
  margin-bottom: 4rpx;
}

.device-location {
  color: #888888;
  font-size: 24rpx;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999999;
  font-size: 28rpx;
}