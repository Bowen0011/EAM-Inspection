.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.device-header {
  background: linear-gradient(135deg, #c62828, #e53935);
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.device-code-text {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
}

.device-name-text {
  color: rgba(255,255,255,0.85);
  font-size: 28rpx;
  margin-top: 6rpx;
}

.form-body {
  flex: 1;
  padding-bottom: 120rpx;
}

.form-section {
  background: #ffffff;
  margin: 16rpx 16rpx 0;
  border-radius: 12rpx;
  padding: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.required-star { color: #c62828; }

.form-item {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child { border-bottom: none; }

.item-label {
  font-size: 28rpx;
  color: #555555;
  margin-bottom: 8rpx;
}

.input-group {
  display: flex;
  align-items: center;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 12rpx;
  background: #fafafa;
}

.input-group.input-error {
  border-color: #c62828;
  background: #fff5f5;
}

.number-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  padding: 0 8rpx;
}

.unit-label {
  font-size: 26rpx;
  color: #888888;
  padding-left: 8rpx;
}

.error-text {
  color: #c62828;
  font-size: 24rpx;
  margin-top: 6rpx;
  display: block;
}

.range-hint {
  color: #999999;
  font-size: 22rpx;
  margin-top: 4rpx;
  display: block;
}

.switch-group {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.switch-label {
  font-size: 28rpx;
  color: #999999;
}

.switch-label.active { color: #1a73e8; font-weight: bold; }

.text-input {
  width: 100%;
  height: 120rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 12rpx;
  font-size: 28rpx;
  background: #fafafa;
  box-sizing: border-box;
}

.photo-area {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.photo-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.thumb-img { width: 100%; height: 100%; }

.photo-btn {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #ccc;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.photo-btn-icon { font-size: 40rpx; }
.photo-btn-text { font-size: 24rpx; color: #888888; margin-top: 4rpx; }

.remark-input {
  width: 100%;
  height: 160rpx;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  padding: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 16rpx 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.06);
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #1a73e8;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-submit[disabled] {
  background: #c0c0c0;
  color: #888888;
}