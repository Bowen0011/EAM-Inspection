.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.header {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.body {
  width: 100%;
  display: flex;
  justify-content: center;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #1a73e8;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  text-align: center;
}

.login-btn::after {
  border: none;
}

.footer {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.version {
  font-size: 24rpx;
  color: #999;
}
